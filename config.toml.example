# DSNO Processor — default configuration.
# The installer copies this file to "config.toml" on first install (it is NOT
# overwritten on upgrades). Fill in the blanks on first run via the Settings
# screen. See docs/DEPLOY.md for the full deployment / configuration guide.

[general]
language = "en"
data_source = "database"

[paths]
# Network paths used by the team. Adjust per deployment if the mapped drive
# differs. The DSNO .txt working folder and the control spreadsheet.
dsno_directory = "Z:\\Documentação\\ORACLE\\EDI\\DSNO\\WIP"
control_sheet = "Z:\\Documentação\\ORACLE\\EDI\\ASN NAVSTAR\\Control ASN Navistar.xlsx"
customer_sheet = "."
customer_sheet_pre_path = "Z:\\Documentação\\ORACLE\\EDI\\ASN NAVSTAR"
# Folder for the shared internal SQLite DB (dsno_processor.db). Accepts a
# network/UNC path so a team shares one DB. Empty = next to this config file.
# Set this to the shared folder during deployment (see docs/DEPLOY.md).
database_dir = ""

[processor]
bypass_file_size_check = false
keep_original = true

[customer_sheet.cols]
invoice = "Invoice"
booking = "Booking/HAWB"
container = "Container"

[customer_sheet.config]
sheet_name = ""

[control_sheet.cols]
invoice = "INVOICE"
dsno = "ARGUMENT2"
date = "CREATION_DATE"
status = "STATUS"
freight_oracle = "FREIGHT_ORACLE"
freight_softway = "FREIGHT_SOFTWAY"
description = "Obs"

[ebs]
# Oracle EBS web URLs for the Selenium download/upload steps. Fill on deploy.
download_url = ""
upload_url = ""
download_dir = "Z:\\Documentação\\ORACLE\\EDI\\DSNO\\WIP"
upload_dir = "Z:\\Documentação\\ORACLE\\EDI\\DSNO\\WIP\\Processed"
headless = true

[ebs.folders]
download_indices = [
    92,
    95,
    101,
]
upload_index = 92

[credentials]
# EBS web login (personal Cummins SSO). Each user fills this in on first run.
email = ""
password = ""

[oracle]
# Oracle EBS source database (step 1 — Pendências). Fill user/password/dsn on
# deploy. customer_id is the Navistar customer in EBS.
user = ""
password = ""
dsn = ""
customer_id = "3579646"
lookback_months = 1
# Java is required only for the Pendências step. The installer bundles and
# extracts Java 21 and the Oracle JDBC driver into the app folder; these
# relative paths resolve against the install directory at runtime.
jdbc_jar = "java\\ojdbc17.jar"
jvm_path = "java\\jdk-21.0.10"
